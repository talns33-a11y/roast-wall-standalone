{
      "compilerOptions": {
              "target": "ES2020",
              "module": "node16",
              "moduleResolution": "node16",
              "lib": ["ES2020"],
              "outDir": "./dist-server",
              "strict": false,
              "esModuleInterop": true,
              "skipLibCheck": true,
              "resolveJsonModule": true
      },
      "include": ["server/**/*", "roast-wall/**/*"],
      "exclude": ["node_modules", "dist", "dist-server"]
}
