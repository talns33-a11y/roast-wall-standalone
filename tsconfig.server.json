{
        "compilerOptions": {
                  "target": "ES2020",
                  "module": "node16",
                  "moduleResolution": "node16",
                  "lib": ["ES2020"],
                  "outDir": "./dist-server",
                  "rootDir": ".",
                  "strict": false,
                  "esModuleInterop": true,
                  "skipLibCheck": true,
                  "resolveJsonModule": true
        },
        "include": ["server/**/*"],
        "exclude": ["node_modules", "dist", "dist-server", "roast-wall/roast-app", "roast-wall/roast-platform", "roast-wall/roast-service/roast-service.spec.ts"]
}
