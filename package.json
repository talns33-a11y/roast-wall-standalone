{
  "name": "million-ai-roast-wall",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "The Million AI Roast Wall - standalone single-process production build.",
  "scripts": {
    "build:web": "vite build roast-wall/roast-app",
    "build:server": "tsc -p tsconfig.server.json",
    "build": "npm run build:web && npm run build:server",
    "start": "node dist-server/server/index.js",
    "start:local": "node --env-file=.env dist-server/server/index.js"
  },
  "dependencies": {
    "express": "^4.19.2",
    "mongoose": "^8.4.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^20.12.12",
    "@vitejs/plugin-react": "^4.3.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-router-dom": "^6.23.1",
    "typescript": "^5.4.5",
    "vite": "^5.2.11"
  }
}
